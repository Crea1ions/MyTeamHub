# Runtime directory structure (but preserve with .gitkeep)
runtime/*
!runtime/.gitkeep
!runtime/**/

# Legacy standalone runtime files (if not migrated yet)
logs/
playwright-screenshots/
test-results/
.cache/
.playwright/

# Data runtime — moved to runtime/
data/sessions-index.json
data/agents/
data/projects/*/sessions/
data/projects/*/execution.log

# Audit reports (horodatés)
AUDIT_*.md
FIX_*.md
UI_UX_AUDIT_*.md

