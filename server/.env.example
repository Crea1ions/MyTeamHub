# Example environment variables for server
# Replace placeholders with actual values (do NOT commit real secrets)

# Token used by the server to authenticate to OpenClaw (used by `/api/proxy/openclaw`).
# In CI: add this as a repository secret named `OPENCLAW_TOKEN` (Actions → Secrets).
# The token must include the `operator.write` scope for `chat.send` to succeed.
OPENCLAW_TOKEN=your_openclaw_token_here

PORT=3001

# Other optional variables used by services
# MODEL_ENDPOINT=http://127.0.0.1:18789
